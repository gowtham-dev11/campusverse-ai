# Only needed if the frontend and backend are deployed as two SEPARATE
# services (e.g. frontend on Vercel/Netlify, backend on Render/Railway).
# Set this to the backend's public URL, including the /api suffix, e.g.:
#   VITE_API_URL=https://campusverse-backend.onrender.com/api
#
# Leave this unset for:
#   - local dev (the Vite dev-server proxy in vite.config.js handles it), or
#   - the single-service Docker deployment (see ../DEPLOYMENT.md), where
#     server.js serves this build itself from the same origin.
VITE_API_URL=
