# ============================================================================
# Gemini AI — two interchangeable providers, same @google/genai client.
# Pick ONE setup below. Which one is active is auto-detected (Vertex wins if
# GOOGLE_CLOUD_PROJECT is set), or force it with GEMINI_PROVIDER=vertex|studio.
# ============================================================================

# --- Option A: Gemini Developer API (AI Studio key) -----------------------
# Simplest for local dev / hackathon demos. Get a key from
# https://aistudio.google.com/apikey. Uses AI Studio's own free tier or
# whatever billing you've linked there.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Option B: Vertex AI (Google Cloud — spends Cloud Billing credit, e.g.
# a $300 free trial) -------------------------------------------------------
# 1. Create/select a project at https://console.cloud.google.com
# 2. Enable the Vertex AI API for it:
#    https://console.cloud.google.com/apis/library/aiplatform.googleapis.com
# 3. Make sure a Cloud Billing account (your $300 trial) is linked to the
#    project — Vertex AI usage draws from that, not from AI Studio.
# 4. Authenticate the backend with Application Default Credentials, either:
#      a) locally: run `gcloud auth application-default login`, or
#      b) via a service account: create one with the "Vertex AI User" role,
#         download its JSON key, and point GOOGLE_APPLICATION_CREDENTIALS
#         at the file path (keep this file OUT of git — see .gitignore).
# 5. Set the two vars below (leave GEMINI_API_KEY blank/unset — Vertex mode
#    ignores it):
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional — force a specific provider instead of relying on auto-detection.
# GEMINI_PROVIDER=vertex

# Optional — defaults to gemini-flash-latest if unset. This alias always
# points to Google's current stable Flash model, so it won't 404 when Google
# retires a specific dated version (as happened with gemini-2.5-flash). Same
# model id works on both providers.
GEMINI_MODEL=gemini-flash-latest

# Optional — image model used by the Nano Banana Freshers' Welcome poster
# generator (POST /api/admin/poster). Defaults to gemini-2.5-flash-image.
# If Google retires that version for your key, try gemini-3.1-flash-image.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

PORT=5000

# Neon Postgres connection string. Get this from your Neon project ->
# Connection Details -> "Pooled connection". Must include ?sslmode=require.
# e.g. postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/campusverse?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/campusverse?sslmode=require"

# Secret used to sign Admin/Faculty JWT session tokens. Generate your own,
# e.g. with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
